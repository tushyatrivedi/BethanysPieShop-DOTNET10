@using BethanysPieShop_DOTNET10.Models
@model IEnumerable<Pie>

<!DOCTYPE html>
<html>
<head>
    <title>Bethany's Pie Shop</title>
    <link href="https://fonts.googleapis.com/css?family=Work+Sans" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
	<div class="container">
		<header>
			<nav class="navbar navbar-expand-lg navbar-dark fixed-top bg-primary" aria-label="Bethany's Pie Shop navigation header">
				<div class="container-xl">
					<a class="navbar-brand" href="/">
						<img src="/images/bethanys-pie-shop-logo.png" width="151" height="47"
							 class="d-inline-block align-top mb-2 mt-1" alt="Bethany's Pie Shop Logo">
					</a>
					<div class="collapse navbar-collapse" id="navbarCollapse">
						<ul class="navbar-nav me-auto mb-2 mb-lg-0">
							<li class="nav-item">
								<a href="/Pie/List" class="nav-link">Pies</a>
							</li>
							<li class="nav-item">
								<a href="/Contact/Index" class="nav-link">Contact</a>
							</li>

						</ul>
					</div>
				</div>
			</nav>
		</header>

		<h1 class="mt-5 pt-4">Pies</h1>

		<div class="row row-cols-1 row-cols-md-3 g-4">
			@foreach (var pie in Model)
			{
				<div class="col">
					<div class="card pie-card h-100 position-relative">
						@if (!string.IsNullOrWhiteSpace(pie.ImageThumbnailUrl))
						{
							<a href="/Pie/Details/@pie.PieId" title="@pie.Name">
								<img src="@pie.ImageThumbnailUrl"
									 class="card-img-top"
									 width="200"
									 height="300"
									 alt="@pie.Name"
									 loading="lazy"
									 decoding="async">
							</a>
						}
						else
						{
							<a href="/Pie/Details/@pie.PieId" title="@pie.Name"
							   class="d-flex align-items-center justify-content-center bg-light"
							   style="height:200px;">
								<span class="text-muted">No image</span>
							</a>
						}

						<div class="card-body pie-button d-flex flex-column">
							<div class="d-flex justify-content-between align-items-start mt-2">
								<h2 class="h5 text-start mb-0">
									<a href="/Pie/Details/@pie.PieId" class="pie-link stretched-link">@pie.Name</a>
								</h2>
								<h5 class="text-nowrap mb-0">
									@pie.Price.ToString("c")
								</h5>
							</div>

							@if (!string.IsNullOrWhiteSpace(pie.ShortDescription))
							{
								<p class="text-muted mt-2 mb-0">@pie.ShortDescription</p>
							}
						</div>
					</div>
				</div>
			}
		</div>
	</div>

</body>
</html>
