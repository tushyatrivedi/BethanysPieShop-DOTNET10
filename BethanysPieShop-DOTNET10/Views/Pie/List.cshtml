@using BethanysPieShop_DOTNET10.Models
@model IEnumerable<Pie>

<!DOCTYPE html>
<html>
<head>
    <title>Bethany's Pie Shop</title>
</head>
<body>
    <h2>@ViewBag.CurrentCategory</h2>
    @foreach (var pie in Model)
    {
        <div>
            <h2>
                <a href="/Pie/Details/@pie.PieId">
                    @pie.Name
                </a>
            </h2>
            <h3>@pie.ShortDescription</h3>
            <h4>Price: @pie.Price.ToString("C")</h4>
        </div>
    }

</body>
</html>
